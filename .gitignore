# Cargo / Rust build output — generated, never committed.
target/
**/*.rs.bk

# Buildroot output lives INSIDE the buildroot/upstream/ submodule, which
# manages its own .gitignore (output/, dl/, etc.). Our .gitmodules sets
# `ignore = dirty` so those build artefacts never appear in `git status`.
# scripts/build-buildroot.sh symlinks final images here for qemu.sh:
buildroot/images/

# ISO build artefacts — iso/build/ is the staging dir grub-mkrescue
# wants; iso/drdros.iso is the final output.
iso/build/
iso/*.iso

# Claude Code local session/agent state — never committed.
.claude/

# Editor and IDE noise.
.vscode/
.idea/
*.swp
*.swo
*~

# OS noise.
.DS_Store
Thumbs.db
