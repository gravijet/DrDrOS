# Cargo / Rust build output — generated, never committed.
target/
**/*.rs.bk

# Buildroot output lives INSIDE the buildroot/upstream/ submodule, which
# manages its own .gitignore (output/, dl/, etc.). Our .gitmodules sets
# `ignore = dirty` so those build artefacts never appear in `git status`.

# ISO build artefacts.
iso/build/
iso/*.iso

# Editor and IDE noise.
.vscode/
.idea/
*.swp
*.swo
*~

# OS noise.
.DS_Store
Thumbs.db
