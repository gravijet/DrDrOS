# DrDrOS kernel config fragment — framebuffer support.
#
# DrDrOS is a framebuffer-only operating system: every GUI component
# (drdr-fb, drdr-font, drdr-ui, drdr-demo) and the drdr-init boot splash
# mmaps /dev/fb0 directly. There is no X11, no Wayland, no DRM-aware
# client code anywhere in the userland.
#
# The stock Buildroot `x86_64` linux defconfig ships NO framebuffer
# driver at all (CONFIG_FB is not set, no DRM display driver, no fbdev
# emulation). With that kernel /dev/fb0 never appears, drdr-init logs
# "no framebuffer splash: No such file or directory", and the entire
# Phase-3 UI stack is dead on real boots. This fragment adds exactly
# enough to light up a single linear framebuffer:
#
#   DRM_BOCHS            drives QEMU's default `-vga std` (Bochs DISPI)
#                        and `-device bochs-display`.
#   DRM_VIRTIO_GPU       already =y in the base defconfig; covers
#                        `-vga virtio` / `-device virtio-gpu-pci`.
#   DRM_SIMPLEDRM+SYSFB  binds the EFI GOP framebuffer that GRUB hands
#                        over on the ISO / real-UEFI-hardware boot path.
#   DRM_FBDEV_EMULATION  exposes the legacy /dev/fb0 node on top of
#                        whichever DRM driver bound — this is the device
#                        drdr_fb::Framebuffer::open("/dev/fb0") mmaps.
#   FRAMEBUFFER_CONSOLE  also puts the kernel console on the framebuffer
#                        so boot messages are visible on the screen, not
#                        only the serial line.
#
# Buildroot merges this with the base defconfig via the kernel's
# merge_config.sh + `make olddefconfig`, so any symbols these options
# `select` (FB_CORE, etc.) are pulled in automatically.
CONFIG_DRM=y
CONFIG_DRM_BOCHS=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_SYSFB=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
# EFI framebuffer (the legacy /dev/fb0 path some UEFI machines fall
# through to when simpledrm doesn't bind). Cheap to include, decisive
# when needed: without it a panel that hands us a GOP but no DRM
# driver shows boot messages but never gets to userland's /dev/fb0.
CONFIG_FB_EFI=y
CONFIG_FB_SIMPLE=y
# VirtIO GPU — for `-vga virtio` QEMU runs and KVM guests.
CONFIG_DRM_VIRTIO_GPU=y
# Boot-time deferred console — keeps boot messages on screen until the
# real desktop takes over, so a hang at any earlier stage is visible.
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER=y
