# DrDrOS kernel config fragment — input on real hardware.
#
# Why this exists
# ───────────────
# linux-fb.config lights up /dev/fb0. This file lights up the *input*
# side — the difference between a usable machine and the "boots, draws,
# then nothing happens" report from real hardware (Surface Go 2 tablet,
# Lenovo ThinkPad T14 laptop, etc.).
#
# Two very different machines, two very different input stacks:
#
#   Surface Go 2 (tablet, no PS/2):
#     - Type Cover keyboard + touchpad: not a USB device — it talks to
#       the **Surface Aggregator Module** (SAM) over a serial bus
#       (TTYPORT controller), then SAM exposes a virtual HID device.
#       Needs CONFIG_SURFACE_AGGREGATOR + the SAM HID/KBD bus drivers.
#     - Touchscreen: Intel Precise Touch & Stylus (IPTS) on most units,
#       I2C-HID on some firmware revisions. We enable BOTH paths.
#     - Power/volume buttons: ACPI buttons (already in defconfig).
#
#   ThinkPad T14 (clamshell, PS/2 + USB):
#     - Internal keyboard: i8042 PS/2 (already worked).
#     - Touchpad: PS/2 Synaptics or Elantech protocols — *not* a plain
#       PS/2 mouse; needs PS2_SYNAPTICS / PS2_ELANTECH protocol modules.
#     - TrackPoint: PS/2 with its own driver.
#     - ThinkPad-special keys + LEDs: thinkpad_acpi.
#
# Everything DrDrOS reads is an evdev node (`/dev/input/eventN`), so
# CONFIG_INPUT_EVDEV is mandatory. Most other symbols are =y so a
# defconfig that trims them can't break a real boot.

# ─── evdev — the only input ABI DrDrOS uses ──────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_MOUSEDEV=y
CONFIG_INPUT_JOYDEV=y
CONFIG_INPUT_LEDS=y

# ─── Legacy PS/2 (QEMU + every clamshell laptop) ─────────────────────
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_SERIO_SERPORT=y
CONFIG_SERIO_LIBPS2=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_MOUSE_PS2=y
# Touchpad protocols (ThinkPad T14: Synaptics or Elantech depending on
# the build; Synaptics_RMI4 is the modern variant, also for Dell/HP).
# These =y guarantee `Two-finger scrolling works` on a clamshell.
CONFIG_MOUSE_PS2_SYNAPTICS=y
CONFIG_MOUSE_PS2_SYNAPTICS_SMBUS=y
CONFIG_MOUSE_PS2_ELANTECH=y
CONFIG_MOUSE_PS2_ELANTECH_SMBUS=y
CONFIG_MOUSE_PS2_TRACKPOINT=y
CONFIG_MOUSE_PS2_FOCALTECH=y
CONFIG_MOUSE_PS2_SENTELIC=y
CONFIG_MOUSE_PS2_ALPS=y
CONFIG_MOUSE_PS2_CYPRESS=y
# RMI4 over SMBus / I2C — Synaptics newer protocol.
CONFIG_RMI4_CORE=y
CONFIG_RMI4_SMB=y
CONFIG_RMI4_F03=y
CONFIG_RMI4_F11=y
CONFIG_RMI4_F12=y
CONFIG_RMI4_F30=y

# ─── USB stack + host controllers ────────────────────────────────────
# xHCI is what every machine from the last decade uses; EHCI/OHCI/UHCI
# cover older ports and QEMU. The HCD_PLATFORM ones cover SoCs that
# don't enumerate over PCI (some Surface revisions).
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_COMMON=y
CONFIG_USB_ANNOUNCE_NEW_DEVICES=y
CONFIG_USB_DEFAULT_PERSIST=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_PCI=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PCI=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB_HUB_USB251XB=y

# USB-C / Power Delivery — Surface Go 2 charges + Type-Cover power
# arbitration runs through here. Without UCSI the controller may never
# bring the device up on AC.
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y
CONFIG_TYPEC_UCSI=y
CONFIG_UCSI_ACPI=y
CONFIG_UCSI_CCG=y

# ─── HID core + drivers ──────────────────────────────────────────────
CONFIG_HID=y
CONFIG_HID_BATTERY_STRENGTH=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_USB_HIDDEV=y
CONFIG_HID_MULTITOUCH=y
CONFIG_HID_MICROSOFT=y
CONFIG_HID_LOGITECH=y
CONFIG_HID_LOGITECH_DJ=y
CONFIG_HID_LOGITECH_HIDPP=y
CONFIG_HID_APPLE=y
CONFIG_HID_LENOVO=y
CONFIG_HID_ELAN=y
CONFIG_HID_ELO=y
CONFIG_HID_WACOM=y
CONFIG_HID_ALPS=y
CONFIG_HID_ASUS=y
CONFIG_HID_BELKIN=y
CONFIG_HID_CHERRY=y
CONFIG_HID_CYPRESS=y
CONFIG_HID_DELL=y
CONFIG_HID_HOLTEK=y
CONFIG_HID_KENSINGTON=y
CONFIG_HID_NTRIG=y
CONFIG_HID_PRIMAX=y
CONFIG_HID_REDRAGON=y
CONFIG_HID_SAMSUNG=y
CONFIG_HID_SUNPLUS=y
CONFIG_INPUT_TOUCHSCREEN=y
# Generic USB touchscreens (some external panels, some Wacom tablets).
CONFIG_TOUCHSCREEN_USB_COMPOSITE=y
CONFIG_TOUCHSCREEN_USB_EGALAX=y
CONFIG_TOUCHSCREEN_USB_PANJIT=y
CONFIG_TOUCHSCREEN_USB_3M=y
CONFIG_TOUCHSCREEN_USB_ITM=y
CONFIG_TOUCHSCREEN_USB_GENERAL_TOUCH=y
CONFIG_TOUCHSCREEN_GOODIX=y
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_I2C=y
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_SPI=y
CONFIG_TOUCHSCREEN_ELAN=y
CONFIG_TOUCHSCREEN_HIDEEP=y
CONFIG_TOUCHSCREEN_ILITEK=y
CONFIG_TOUCHSCREEN_SILEAD=y
CONFIG_TOUCHSCREEN_WACOM_I2C=y

# ─── I2C + I2C-HID (Surface Go 2 touchscreen, many laptop touchpads) ─
# I2C-HID is how the Surface Go 2's panel exposes itself when the IPTS
# firmware is loaded in HID mode — that path is well-supported by the
# stock kernel and works without any userspace daemon.
CONFIG_I2C=y
CONFIG_I2C_HID=y
CONFIG_I2C_HID_ACPI=y
CONFIG_I2C_HID_OF=y
# Intel Low Power Subsystem — the I2C / UART / SPI controllers on
# Surface (and most modern x86 laptops) live behind LPSS, not as PCI
# devices in the traditional sense. Without these the whole bus is
# invisible.
CONFIG_X86_INTEL_LPSS=y
CONFIG_MFD_INTEL_LPSS=y
CONFIG_MFD_INTEL_LPSS_PCI=y
CONFIG_MFD_INTEL_LPSS_ACPI=y
CONFIG_I2C_DESIGNWARE_CORE=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y
CONFIG_I2C_DESIGNWARE_PCI=y
CONFIG_I2C_DESIGNWARE_BAYTRAIL=y
CONFIG_I2C_I801=y
CONFIG_I2C_ISCH=y
CONFIG_I2C_SMBUS=y
CONFIG_I2C_CHARDEV=y
# Pinctrl for Intel SoCs — Amber Lake (Surface Go 2), Tiger Lake (T14),
# Ice Lake, Comet Lake, Alder Lake all use these. Pinctrl is what binds
# the I2C / UART pins to their controllers; without it I2C-HID silently
# never enumerates because the IRQ never gets routed.
CONFIG_PINCTRL=y
CONFIG_PINCTRL_INTEL=y
CONFIG_PINCTRL_BROXTON=y
CONFIG_PINCTRL_GEMINILAKE=y
CONFIG_PINCTRL_CANNONLAKE=y
CONFIG_PINCTRL_ICELAKE=y
CONFIG_PINCTRL_TIGERLAKE=y
CONFIG_PINCTRL_LEWISBURG=y
CONFIG_PINCTRL_ALDERLAKE=y
CONFIG_PINCTRL_METEORLAKE=y
CONFIG_PINCTRL_SUNRISEPOINT=y
CONFIG_PINCTRL_LYNXPOINT=y
CONFIG_PINCTRL_DENVERTON=y

# ─── Serial-device bus (Surface Aggregator transport) ────────────────
# Surface Aggregator Module is reached over a TTY-port serial bus; the
# Type Cover keyboard / touchpad and the embedded controller battery
# all proxy through SAM. Without SERIAL_DEV_BUS the SAM driver has no
# transport and the Type Cover is invisible.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_SERIAL_8250_LPSS=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_DEV_CTRL_TTYPORT=y

# ─── Surface Aggregator Module (Surface Go / Go 2 / Pro 7+) ──────────
# This is the SINGLE most important thing for a Surface Go 2 to have
# any input at all once the Type Cover is attached. SAM exposes a
# virtual HID bus; SURFACE_HID + SURFACE_KBD bind keyboards and
# touchpads from the cover to the standard hid layer.
CONFIG_SURFACE_PLATFORMS=y
CONFIG_SURFACE_AGGREGATOR=y
CONFIG_SURFACE_AGGREGATOR_BUS=y
CONFIG_SURFACE_AGGREGATOR_CDEV=y
CONFIG_SURFACE_AGGREGATOR_REGISTRY=y
CONFIG_SURFACE_AGGREGATOR_HUB=y
CONFIG_SURFACE_HID_CORE=y
CONFIG_SURFACE_HID=y
CONFIG_SURFACE_KBD=y
CONFIG_SURFACE_DTX=y
CONFIG_SURFACE_GPE=y
CONFIG_SURFACE_HOTPLUG=y
CONFIG_SURFACE_PLATFORM_PROFILE=y
CONFIG_SURFACE_ACPI_NOTIFY=y

# ─── Intel Precise Touch & Stylus (Surface Go 2 touchscreen) ─────────
# The IPTS hardware on Surface Go 2 is the *only* built-in pointer
# when no Type Cover is attached. The in-tree driver (Linux 6.5+)
# exposes it as a HID multitouch device, which our PointerReader
# already decodes (EV_ABS / ABS_MT_POSITION_*). No userspace daemon
# needed for basic finger input.
CONFIG_INTEL_ISH_HID=y
CONFIG_INTEL_ISH_FIRMWARE_DOWNLOADER=y
CONFIG_HID_IPTS=y
CONFIG_HID_ITHC=y

# ─── ThinkPad / Lenovo platform helpers ──────────────────────────────
CONFIG_THINKPAD_ACPI=y
CONFIG_THINKPAD_ACPI_ALSA_SUPPORT=y
CONFIG_THINKPAD_ACPI_VIDEO=y
CONFIG_THINKPAD_ACPI_HOTKEY_POLL=y
CONFIG_THINKPAD_LMI=y
CONFIG_INTEL_HID_EVENT=y
CONFIG_INTEL_VBTN=y
CONFIG_DELL_LAPTOP=y
CONFIG_DELL_WMI=y
CONFIG_HP_WMI=y
CONFIG_ACPI_WMI=y

# ─── ACPI + Power button + battery (needed for both machines) ────────
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_VIDEO=y
CONFIG_ACPI_FAN=y
CONFIG_ACPI_THERMAL=y
CONFIG_ACPI_LPIT=y
CONFIG_ACPI_PROCESSOR=y

# ─── IIO (some Surface tablets expose sensors via this) ──────────────
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_TRIGGER=y

# ─── Hotplug — devtmpfs auto-mount, uevents over the kernel netlink ──
# Our drdr-init does the mount itself, but devtmpfs needs to be enabled
# for /dev to ever be populated with new nodes when a USB device or
# Type Cover is plugged in *after* boot.
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_UEVENT_HELPER=y
CONFIG_HOTPLUG_PCI=y
CONFIG_HOTPLUG_PCI_PCIE=y
CONFIG_HOTPLUG_PCI_ACPI=y
