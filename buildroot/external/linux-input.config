# DrDrOS kernel config fragment — input on real hardware.
#
# Why this exists
# ───────────────
# linux-fb.config lights up /dev/fb0. This file lights up the *input*
# side, which the stock x86_64 defconfig only half-covers and which is
# the difference between a usable machine and the "boots, draws, then
# nothing happens" report from a Microsoft Surface Go 2.
#
# A Surface Go 2 is a tablet:
#   - It has NO PS/2. The QEMU dev loop uses an i8042 PS/2 keyboard, so
#     the defconfig's ATKBD path is enough there — but on the Surface the
#     keyboard/touchpad arrive over the **Type Cover, which enumerates as
#     USB HID** behind an xHCI controller. No USB-HID + xHCI ⇒ no
#     keyboard, no mouse, ever.
#   - Its touchscreen is an HID device (generic touchscreens and the
#     QEMU `usb-tablet` we now decode in absolute mode are HID too), so
#     hid-multitouch + the HID core must be in the kernel.
#   - Every device DrDrOS reads is an evdev node (`/dev/input/eventN`),
#     so CONFIG_INPUT_EVDEV is mandatory, not optional.
#
# These are all already present in mainline `x86_64_defconfig`, but
# pinning them =y here makes the requirement explicit and survives a
# defconfig that trims them. merge_config.sh + `make olddefconfig` pull
# in anything they `select` (HID core, USB core, …) automatically.

# evdev: the ONLY input ABI DrDrOS uses. Without it /dev/input is empty.
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y

# Legacy PS/2 — the QEMU development path (i8042 keyboard + mouse).
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSEDEV=y
CONFIG_MOUSE_PS2=y

# USB stack + host controllers. xHCI is what a Surface (and any machine
# from the last decade) uses; EHCI/OHCI/UHCI cover older ports and VMs.
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_PCI=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_UHCI_HCD=y

# HID core + the drivers a keyboard / mouse / touchscreen bind to. The
# Surface Type Cover is a standard boot-protocol HID keyboard + a
# multitouch touchpad; hid-multitouch also drives most USB touchscreens
# and the QEMU `usb-tablet` absolute pointer the desktop now supports.
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_HID_MULTITOUCH=y
CONFIG_HID_MICROSOFT=y
CONFIG_INPUT_TOUCHSCREEN=y

# I2C-HID: many tablet touchscreens (and some Type Cover revisions) are
# I2C-HID rather than USB-HID. Cheap to include, decisive when needed.
CONFIG_I2C=y
CONFIG_I2C_HID=y
CONFIG_I2C_HID_ACPI=y
